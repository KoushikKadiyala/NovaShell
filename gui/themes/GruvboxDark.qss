/* Gruvbox Dark Theme */
QWidget {
    background-color: #282828;
    color: #ebdbb2;
}

QPlainTextEdit {
    background-color: #282828;
    color: #ebdbb2;
    border: 1px solid #3c3836;
    selection-background-color: #458588;
    selection-color: #282828;
}

QMainWindow {
    background-color: #282828;
    color: #ebdbb2;
}

QStatusBar {
    background-color: #458588;
    color: #ebdbb2;
    border-top: 1px solid #3c3836;
}
