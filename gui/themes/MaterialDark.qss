/* Material Dark Theme */
QWidget {
    background-color: #212121;
    color: #ffffff;
}

QPlainTextEdit {
    background-color: #212121;
    color: #ffffff;
    selection-background-color: #00bcd4;
    selection-color: #212121;
}

QMainWindow {
    background-color: #303030;
    color: #ffffff;
}

QStatusBar {
    background-color: #00bcd4;
    color: #212121;
    border-top: 1px solid #212121;
}
