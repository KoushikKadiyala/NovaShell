/* Dark Theme */
QWidget {
    background-color: #1e1e1e;
    color: #e0e0e0;
}

QPlainTextEdit {
    background-color: #1e1e1e;
    color: #e0e0e0;
    border: 1px solid #3e3e3e;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
}

QMainWindow {
    background-color: #252526;
    color: #e0e0e0;
}

QStatusBar {
    background-color: #007acc;
    color: #ffffff;
    border-top: 1px solid #1e1e1e;
}
