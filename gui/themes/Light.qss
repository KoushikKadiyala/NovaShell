/* Light Theme */
QWidget {
    background-color: #ffffff;
    color: #000000;
}

QPlainTextEdit {
    background-color: #ffffff;
    color: #000000;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
}

QMainWindow {
    background-color: #f5f5f5;
    color: #000000;
}

QStatusBar {
    background-color: #e8e8e8;
    color: #000000;
    border-top: 1px solid #cccccc;
}
