/* Solarized Light Theme */
QWidget {
    background-color: #fdf6e3;
    color: #657b83;
}

QPlainTextEdit {
    background-color: #fdf6e3;
    color: #657b83;
    border: 1px solid #eee8d5;
    selection-background-color: #268bd2;
    selection-color: #fdf6e3;
}

QMainWindow {
    background-color: #fdf6e3;
    color: #657b83;
}

QStatusBar {
    background-color: #268bd2;
    color: #fdf6e3;
    border-top: 1px solid #eee8d5;
}
